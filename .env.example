# Copy this file's contents into Vercel → Project → Settings → Environment Variables.
# Never commit a real .env file with actual values to git.

# Supabase → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # secret — server-side only, never expose to the browser

# YooKassa → your shop's API keys section
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Your live site URL (used to build the YooKassa return_url). Set this once you have a domain;
# until then the code falls back to the request's own host.
SITE_URL=https://your-domain.com
